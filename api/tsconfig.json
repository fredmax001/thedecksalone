{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleDetection": "force",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": false
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
